{
  "name": "ai-agent-studio",
  "version": "0.1.0",
  "private": true,
  "description": "DevAgent Hub — standalone multi-agent development workspace with OpenVSCode Server, GitHub automation and custom AI agent chains.",
  "workspaces": [
    "apps/web",
    "installer"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "lint:web": "npm --workspace apps/web run lint",
    "dev:installer": "npm --workspace installer run dev",
    "check:installer": "npm --workspace installer run check",
    "build:installer": "npm --workspace installer run dist:dir",
    "dist:installer": "npm --workspace installer run dist",
    "dist:installer:win": "npm --workspace installer run dist:win",
    "dist:installer:linux": "npm --workspace installer run dist:linux",
    "install:cli": "node installer/cli.js",
    "start:api": "uvicorn app.main:app --reload --reload-exclude=.tools/* --host 0.0.0.0 --port 8000 --app-dir services/agent-api",
    "typecheck": "npm --workspace apps/web run typecheck",
    "smoke:api": "node scripts/run_python_script.js scripts/smoke_devhub_api.py",
    "smoke:installer": "node scripts\\smoke_installer_prepare.js && node scripts\\smoke_installer_runner.js",
    "smoke:installer-runner": "node scripts\\smoke_installer_runner.js",
    "test:url-builder": "python scripts/test_url_builder.py",
    "verify": "npm run check:installer && npm run smoke:installer && npm run typecheck && npm run smoke:api && npm run test:url-builder"
  },
  "engines": {
    "node": ">=22.12"
  }
}
